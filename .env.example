# NSE TradeAI v7.0 · Environment Variables

# Angel One SmartAPI
ANGEL_CLIENT_ID=A123456
ANGEL_API_KEY=your_smartapi_key
ANGEL_MPIN=1234
ANGEL_TOTP_TOKEN=BASE32_SECRET_FROM_ANGEL_APP

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_CHAT_ID=123456789

# Database (Railway auto-sets this)
DATABASE_URL=postgresql://...

# Mobile Auth
MOBILE_AUTH_TOKEN=generate_random_64_char_string_here

# Trading Mode
LIVE_TRADING=false
NODE_ENV=production

# Optional AI
USE_AI_SENTIMENT=false
ANTHROPIC_API_KEY=sk-ant-...
