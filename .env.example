# ═══════════════════════════════════════════════════════════════════
# NSE TradeAI Bot v6.4 · Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ─── ANGEL ONE SMARTAPI (required) ──────────────────────────────────
ANGEL_CLIENT_ID=A123456
ANGEL_API_KEY=your_smartapi_key_here
ANGEL_MPIN=1234
ANGEL_TOTP_TOKEN=JBSWY3DPEHPK3PXP

# ─── TELEGRAM BOT (required) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ─── DATABASE (auto-set by Railway) ─────────────────────────────────
DATABASE_URL=postgresql://...

# ─── MOBILE API AUTH (required) ─────────────────────────────────────
MOBILE_AUTH_TOKEN=generate_64_char_random_string

# ─── TRADING MODE ───────────────────────────────────────────────────
LIVE_TRADING=false
NODE_ENV=production

# ─── AI FEATURES (optional) ─────────────────────────────────────────
# Set USE_AI_SENTIMENT=true to enable Claude AI sentiment validation
# Requires ANTHROPIC_API_KEY (get from console.anthropic.com)
USE_AI_SENTIMENT=false
ANTHROPIC_API_KEY=your_anthropic_key_here


